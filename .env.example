# ─── Global Search Agent — environment ───────────────────────────────
# Copy to .env and fill in. Never commit .env.

# Server
PORT=4100
NODE_ENV=development

# Database file (better-sqlite3). Relative to project root.
DB_PATH=./data/search-agent.db

# Encryption key for connected-app credentials at rest (AES-256-GCM).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Session/admin cookie signing secret.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Bootstrap tenant — created on first migrate if no tenants exist.
BOOTSTRAP_TENANT_NAME=Demo Tenant

# Optional: pin the bootstrap tenant's API key + webhook secret. RECOMMENDED
# for hosted deploys (Railway / Cloud Run) so the credentials are known up
# front and never lost in scrolled-away container logs. Leave blank locally
# to have them generated and printed once. A pinned API key must be >= 24 chars.
# Generate: node -e "console.log('gsa_'+require('crypto').randomBytes(24).toString('hex'))"
BOOTSTRAP_API_KEY=
BOOTSTRAP_WEBHOOK_SECRET=

# ─── Admin / Settings page ───────────────────────────────────────────
# The Settings page is where an administrator configures which tenant key
# the public console proxies with (so every visitor is connected with no
# key to enter). It is guarded by a username + password + mandatory TOTP
# 2FA login.
#
# FIRST ADMIN — two ways to create it:
#   1. Set ADMIN_USERNAME + ADMIN_PASSWORD below. On first boot the admin
#      row is seeded; the admin then completes a one-time 2FA enrollment
#      (scan a QR) at first login.
#   2. Leave both blank. The one-time /setup page handles first-run
#      enrollment (username + password + 2FA QR) in the browser.
# Either way, /setup is permanently closed once an admin exists.
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Admin session lifetime in hours (how long a Settings login stays valid).
ADMIN_SESSION_HOURS=12

# Admin brute-force lockout: after this many consecutive failed logins the
# account is locked for ADMIN_LOCK_MINUTES.
ADMIN_MAX_FAILED_LOGINS=5
ADMIN_LOCK_MINUTES=15

# Per-IP rate limit for the admin auth endpoints (/api/admin/*), per minute.
ADMIN_AUTH_RATE_LIMIT_PER_MIN=30

# CSV ingestion limits
MAX_CSV_BYTES=5242880
MAX_CSV_ROWS=10000

# Per-tenant API rate limit (requests per minute)
RATE_LIMIT_PER_MIN=120

# SSRF policy. Connectors pointing at private/loopback addresses are refused
# by default. Set true ONLY for local dev / CI when sweeping a mock app on
# 127.0.0.1. Ignored (forced off) when NODE_ENV=production.
ALLOW_PRIVATE_CONNECTORS=false

# ─── Vistage / Claritas CRM (Common API V1) ──────────────────────────
# Only used by test/vistage-connect.mjs and test/vistage-sweep.mjs (the
# live-connection probes). At runtime the agent stores these per-connector
# in the encrypted credential bundle — they do NOT need to be set in env to
# operate a registered connector.
#
# Treat the Client ID / Secret Key as SECRETS. Never commit values. On
# Railway, set them as service variables only if you actually run the live
# probes there (most operators don't).
#
# VISTAGE_BASE_URL=https://teststudio.claritascrm.com/api/CommonService.svc
# VISTAGE_CLIENT_ID=
# VISTAGE_SECRET_KEY=
# VISTAGE_USERNAME=
# VISTAGE_PASSWORD=
# VISTAGE_COMPANY_ID=3
# VISTAGE_COMPANY_PREFIX=VT
# VISTAGE_USER_ID=
# VISTAGE_USER_NAME=admin
# VISTAGE_USER_MODULE_ID=64
